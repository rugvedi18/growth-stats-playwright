{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "types": [
      "@playwright/test"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@config/*": [
        "config/*"
      ],
      "@fixtures/*": [
        "fixtures/*"
      ],
      "@pages/*": [
        "pages/*"
      ],
      "@test-data/*": [
        "test-data/*"
      ],
      "@utils/*": [
        "utils/*"
      ]
    }
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}
